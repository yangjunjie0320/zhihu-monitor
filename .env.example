# Zhihu Monitor Configuration

# Required: JSON array of monitoring targets
MONITOR_TARGETS=[{"user_id": "ma-qian-zu", "user_name": "马前卒", "webhook_url": "https://open.feishu.cn/open-apis/bot/v2/hook/YOUR_KEY"}]

# Cookie file path (Netscape format)
COOKIE_FILE=/app/cookies/zhihu.com_cookies.txt

# Data and log directories
DATA_DIR=/app/data
LOG_DIR=/app/data/logs

# Debug mode: sends debug notifications every run
DEBUG_MODE=false

# Archive retention in days
ARCHIVE_MAX_DAYS=30

# Hours of silence before sending a reminder
SILENCE_HOURS=24

# Minimum hours between error reports per user
ERROR_REPORT_INTERVAL_HOURS=24

# Minimum days between cookie expiry reminders
COOKIE_REMINDER_INTERVAL_DAYS=5
